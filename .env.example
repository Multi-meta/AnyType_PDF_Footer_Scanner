# PDF Footer Scanner — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit secrets.

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on.
# Render sets PORT automatically; keep 3000 for local dev.
PORT=3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# URL of the frontend that is allowed to call the API.
# Local dev: http://localhost:3000
# Production: your Vercel URL, e.g. https://pdf-footer-scanner.vercel.app
FRONTEND_URL=http://localhost:3000

# ─── Python ──────────────────────────────────────────────────────────────────
# Path to the Python 3 executable used for PDF extraction.
# Leave blank to let the app auto-detect (python / python3 / py -3).
# Windows example: C:\Users\YourName\AppData\Local\Programs\Python\Python311\python.exe
# Linux / Docker:  python3
PDF_FOOTER_SCANNER_PYTHON=
