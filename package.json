{
  "name": "pdf-footer-scanner",
  "version": "1.0.0",
  "description": "PDF Footer Scanner — scan PDFs for text in footer, header, content or full document",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-windows.ps1",
    "setup:windows:install": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-windows.ps1 -InstallTools",
    "build:config": "node scripts/build-frontend-config.js",
    "build:config:prod": "node -e \"process.env.RENDER_URL = process.env.RENDER_URL || ''; require('./scripts/build-frontend-config.js')\""
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf2pic": "^3.2.0",
    "tesseract.js": "^7.0.0"
  }
}
