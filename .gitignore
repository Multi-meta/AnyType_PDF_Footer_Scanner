# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Runtime artifacts (generated at runtime, never commit these) ──────────────
uploads/
results/
uploads/ocr-temp/

# ── Environment / secrets (NEVER commit these) ───────────────────────────────
.env
.env.*
!.env.example

# ── PDF files (user data — never commit) ─────────────────────────────────────
*.pdf

# ── Large binary / compiled files ────────────────────────────────────────────
*.exe
*.traineddata
*.obj
*.o
*.pdb
scan_footer.exe
scan_pdfs.exe

# ── OS generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.vs/
*.suo
*.user

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/